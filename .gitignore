# ── Secrets (never commit these) ─────────────────────────────────────────────
companion/bot_secrets.py

# ── User config (machine-specific) ───────────────────────────────────────────
companion/config.json

# ── Build artifacts ───────────────────────────────────────────────────────────
dist/
build/
*.spec.bak
__pycache__/
*.pyc
*.pyo

