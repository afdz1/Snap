# bot_secrets.py is listed in .gitignore and must NEVER be committed.
#
# Get your bot token from: https://discord.com/developers/applications
# → Your App → Bot → Reset Token
#
# Get your channel ID by right-clicking a channel in Discord
# (Developer Mode must be enabled in Discord settings → Advanced)
# ──────────────────────────────────────────────────────────────────────────────

BOT_TOKEN  = ""
CHANNEL_ID = 0  # integer, e.g. 1003477115058016398

